{
    "key": "group_options_footer",
    "title": "Opciones — Footer",
    "fields": [
        {
            "key": "field_options_footer_contact_blocks",
            "label": "Bloques de contacto (footer)",
            "name": "contact_blocks",
            "type": "repeater",
            "instructions": "Hasta 6 bloques con dirección, teléfonos y emails. Aparecen en el strip superior del footer.",
            "min": 0,
            "max": 6,
            "layout": "block",
            "button_label": "Agregar bloque de contacto",
            "sub_fields": [
                {
                    "key": "field_options_footer_contact_titulo",
                    "label": "Título",
                    "name": "titulo",
                    "type": "text",
                    "instructions": "Ej: Dirección, Mesa Central, Email Principal"
                },
                {
                    "key": "field_options_footer_contact_valor",
                    "label": "Valor",
                    "name": "valor",
                    "type": "textarea",
                    "rows": 2,
                    "instructions": "Texto del bloque (dirección completa, teléfono formateado, email, etc.)"
                },
                {
                    "key": "field_options_footer_contact_enlace",
                    "label": "Enlace (opcional)",
                    "name": "enlace",
                    "type": "url",
                    "instructions": "Para teléfonos usar tel:+56... y para emails mailto:... Si vacío, el bloque no es clickable."
                }
            ]
        },
        { "key": "field_options_footer_copyright", "label": "Copyright", "name": "copyright", "type": "text", "default_value": "© Universidad Diego Portales" },
        {
            "key": "field_options_footer_legal_links",
            "label": "Links legales",
            "name": "legal_links",
            "type": "repeater",
            "layout": "table",
            "sub_fields": [
                { "key": "field_options_footer_legal_label", "label": "Label", "name": "label", "type": "text" },
                { "key": "field_options_footer_legal_url", "label": "URL", "name": "url", "type": "url" }
            ]
        }
    ],
    "location": [[{ "param": "options_page", "operator": "==", "value": "udp-options-footer" }]],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "hide_on_screen": "",
    "active": true,
    "description": "Estructura del footer. Field keys NUEVOS — no había antes (footer del tema viejo era hardcoded)."
}
